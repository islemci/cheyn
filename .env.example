# Shared
API_BASE_URL=http://localhost:3000
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOY_KEY=your_convex_deploy_key
# Optional runtime admin auth token if you decide to protect Convex functions.
# Do not put the deploy key here.
CONVEX_ADMIN_KEY=replace_with_a_long_random_admin_secret

# Convex dashboard env vars, not Vercel env vars:
# BETTER_AUTH_SECRET=replace_with_a_long_random_secret
# Convex env should match production HTTPS domain in production.
# SITE_URL=https://your-domain.com

# Admin route auth for POST /api/v1/devs
ADMIN_API_KEY=replace_with_a_long_random_admin_secret

# Wallet RPC
# Use "mock" locally without a wallet. Use "real" when wallet RPC is reachable.
MONERO_WALLET_MODE=mock
MONERO_RPC_URL=http://127.0.0.1:18082/json_rpc
MONERO_RPC_USER=monero_rpc_user
MONERO_RPC_PASS=monero_rpc_password
MONERO_RPC_TIMEOUT_MS=30000
MONERO_RPC_RETRIES=2
# This path is interpreted on the monero-wallet-rpc host. Start wallet RPC
# with --wallet-dir pointing at the same directory.
WALLET_BASE_DIR=/var/lib/monero/wallets
WALLET_HOSTED_NAME=hosted/cheyn
WALLET_HOSTED_PASSWORD=
VIEW_KEY_ENCRYPTION_KEY=base64_or_hex_32_byte_key
VIEW_KEY_ENCRYPTION_KEY_VERSION=v1
VIEW_ONLY_DONATION_ADDRESS=8AW8DB59Cb5CGe9421RVwWPcmGEEkWt5uTC7XQWxxgnUWaFTFV5hA5uFoNd26gybPcCckxrtzt4hf6Y5w9bn47Pw2NfeiJG
VIEW_ONLY_PROVISIONING_RETRY_DELAY_MS=60000
VIEW_ONLY_PROVISIONING_MAX_ATTEMPTS=3

# Payment behavior
CMC_API_KEY=your_coinmarketcap_api_key
# Worker refreshes XMR/USD at most every 10 minutes.
# 10-minute cadence is about 4,320 calls/month, below a 10,000 credit hard cap.
CMC_PRICE_REFRESH_INTERVAL_MS=600000
CMC_PRICE_CACHE_MAX_AGE_MS=900000
REQUIRED_CONFIRMATIONS=10
# Optional amount-based confirmation policy. Rules are maxAtomic:confirmations.
# Example below means <=0.025 XMR: 1, <=0.1 XMR: 2, <=1 XMR: 3, above: 5.
CONFIRMATION_TIERS=25000000000:1,100000000000:2,1000000000000:3,*:5
CHECKOUT_EXPIRY_MINUTES=60
MIN_CHECKOUT_AMOUNT_ATOMIC=10000000000
# Allows tiny dust-level underpayments caused by fiat conversion/display rounding.
PAYMENT_UNDERPAY_TOLERANCE_ATOMIC=1000000
PLATFORM_FEE_BPS=300
MAX_TOTAL_FEE_BPS=500
PAYOUTS_ENABLED=true
MAX_PAYOUT_ATOMIC=
PAYOUT_REQUIRED_CONFIRMATIONS=10
PAYOUT_RETRY_DELAY_MS=300000
PAYOUT_MAX_FAILURES=3
# Reserve kept in the wallet to pay the Monero network tx fee on payout.
# The worker caps platform fee + reserve to MAX_TOTAL_FEE_BPS for small payments.
PAYOUT_NETWORK_FEE_RESERVE_ATOMIC=20000000
WEBHOOK_RETRY_DELAY_MS=60000
WEBHOOK_MAX_FAILURES=5

# Railway worker
WORKER_POLL_INTERVAL_MS=30000
